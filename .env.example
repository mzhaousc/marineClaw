LLM_SOURCE=OpenAI
OPENAI_API_KEY=replace_with_your_key
MARINE_AGENT_MODEL=gpt-4o
MARINE_AGENT_TIMEOUT=300
MARINE_AGENT_MAX_ITER=20

# Working directory for agent-executed code (use cluster scratch on HPC)
# MARINE_AGENT_WORKDIR=/scratch/$USER/marineclaw_work

# HPC: enable extra system-prompt hints for BLAST threading and BLASTDB (true | 1)
# MARINE_AGENT_HPC_MODE=true

# BLAST+: directory containing pre-built databases (e.g. nr.*). Same as shell BLASTDB.
# BLASTDB=/scratch/your_user/blastdb

# Optional: fixed -num_threads for BLAST+ in generated commands (else use SLURM_CPUS_PER_TASK in scripts)
# MARINE_AGENT_BLAST_NUM_THREADS=16

# Optional Galaxy Bridge settings
GALAXY_URL=https://usegalaxy.org.au
GALAXY_API_KEY=replace_with_your_galaxy_key
